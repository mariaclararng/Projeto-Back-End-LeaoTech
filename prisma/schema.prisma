datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          Int @id @default(autoincrement())
  nome        String
  cpf         String @unique
  email       String @unique
  password    String
  celular     String
  endereco    String
  bairro      String
  cidade      String
  cep         String
  complemento String?
}